{
  "name": "polaris-weweb-styles",
  "version": "2.5.0",
  "description": "SCSS design system + Vue 3 component library for WeWeb custom components following Shopify Polaris design language. Includes mixins, design tokens, theming support, ready-to-use Vue components, and ECharts integration.",
  "main": "index.scss",
  "style": "index.scss",
  "sass": "index.scss",
  "module": "components/index.js",
  "exports": {
    ".": "./index.scss",
    "./components": "./components/index.js",
    "./components/*": "./components/*.vue",
    "./themes/*": "./themes/*.js"
  },
  "files": [
    "index.scss",
    "_variables.scss",
    "_tokens.scss",
    "_mixins.scss",
    "_condition-builder.scss",
    "_chart-card.scss",
    "components",
    "themes",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "polaris",
    "shopify",
    "scss",
    "sass",
    "weweb",
    "vue",
    "vue3",
    "design-tokens",
    "design-system",
    "mixins",
    "css",
    "ui",
    "components",
    "shopify-polaris",
    "admin-ui",
    "component-library",
    "echarts",
    "charts"
  ],
  "author": "rangwand",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rocket-CRM/polaris-weweb-styles.git"
  },
  "bugs": {
    "url": "https://github.com/Rocket-CRM/polaris-weweb-styles/issues"
  },
  "homepage": "https://github.com/Rocket-CRM/polaris-weweb-styles#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "echarts": "^5.5.1",
    "vue-echarts": "^7.0.3"
  },
  "peerDependencies": {
    "sass": ">=1.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": false
    },
    "vue": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
